# QuantEdge Environment Variables
# Copy this file to .env and fill in your keys

# Anthropic API key — get it from https://console.anthropic.com
# Required for QuantEdge AI chatbot
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# FRED API key — get it free from https://fred.stlouisfed.org/docs/api/api_key.html
# Optional — DEMO_KEY works but is rate-limited
REACT_APP_FRED_API_KEY=DEMO_KEY
